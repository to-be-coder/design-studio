# Absolute path to the design-studio vault. Optional — if unset, the app reads
# ~/.design-studio-vault (the same pointer every design-studio skill uses).
# DESIGN_STUDIO_VAULT=/Users/you/hermes

# The command used to run a skill headlessly (Hybrid run). Optional.
# The active project slug and "/<skill-name>" are appended at runtime.
# CLAUDE_BIN=claude
